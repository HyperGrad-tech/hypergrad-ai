---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { tools, priorityMeta, toolsByPriority, type Priority } from '../data/tools';

const priorityOrder: Priority[] = ['P0', 'P1', 'P2'];
const totalTools = tools.length;
const byokCount = tools.filter(t => t.byok).length;
const localCount = totalTools - byokCount;
import { getSisterSites } from '../data/sisterSites';
const sisters = getSisterSites('ai');
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HyperGrad AI — 纯前端 AI 工具箱 · 写作/翻译/总结/Prompt/对话 | BYOK 零中转</title>
  <meta name="description" content="16 个 AI 工具：AI 写作、翻译、总结、标题、营销文案、邮件、周报、代码解释、AI 对话、Prompt 库/优化/生成、Token 计数、Markdown、图片压缩。BYOK 模式密钥本地存储直连官方 API，零中转零存储。" />
  <meta name="keywords" content="ai工具,ai写作,ai翻译,ai总结,ai对话,prompt,提示词,token计数,ai文案,代码解释" />
  <link rel="canonical" href="https://ai.hypergrad.cn/" />
  <meta property="og:title" content="HyperGrad AI — 纯前端 AI 工具箱" />
  <meta property="og:description" content="16 个 AI 工具，BYOK 模式密钥本地存储直连官方 API，我们零中转零存储。" />
  <meta property="og:type" content="website" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <!-- Baidu Tongji（跨子域追踪 hypergrad.cn） -->
  <script is:inline>
var _hmt = _hmt || [];
_hmt.push(['_setCookieDomain', '.hypergrad.cn']);
(function() {
  var hm = document.createElement("script");
  hm.src = "https://hm.baidu.com/hm.js?a778461c432b29b641ee950a9f686a65";
  var s = document.getElementsByTagName("script")[0];
  s.parentNode.insertBefore(hm, s);
})();
  </script>
</head>
<body>
  <!-- DeepSeal 推广条 -->
  <div class="promo-banner" id="promo-banner">
    <span>
      <strong>DeepSeal</strong> — 本地加密笔记应用，你的隐私只有你说了算。
      <a href="https://hypergrad.cn#pricing" target="_blank" rel="noopener">免费下载 →</a>
    </span>
    <span class="promo-close" onclick="document.getElementById('promo-banner').style.display='none'">×</span>
  </div>

  <Header />

  <main class="main" style="max-width: var(--content-max); margin: 0 auto;">
    <!-- 快速导航工具条（置顶，让用户进站即可点工具） -->
    <section class="quick-nav">
      <div class="quick-nav-title">快速访问 · 全部 {totalTools} 个工具（{byokCount} BYOK + {localCount} 纯前端）</div>
      <div class="quick-nav-chips">
        {tools.map(t => (
          <a href={`/${t.slug}`} class="quick-chip">
            <span class="quick-chip-icon">{t.icon}</span>
            <span>{t.name}</span>
          </a>
        ))}
      </div>
    </section>


    <!-- 按优先级分区 -->
    {priorityOrder.map(p => {
      const list = toolsByPriority(p);
      const meta = priorityMeta[p];
      return (
        <section class="priority-section">
          <div class="priority-header">
            <h2>{meta.label}</h2>
            <span class="priority-tag" style={`background:${meta.bg};color:${meta.color}`}>{p} · {list.length} 个</span>
            <span class="priority-desc">{meta.desc}</span>
          </div>
          <div class="tool-grid">
            {list.map(t => (
              <a href={`/${t.slug}`} class="tool-card-home">
                <div class="card-icon">{t.icon}</div>
                <h3>{t.name}</h3>
                <p>{t.desc}</p>
                <div class="card-meta">
                  <span>{t.category}</span>
                  <span>{t.byok ? '需 API Key' : '纯前端'}</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

<!-- SISTER-CARDS -->
    <section class="sister-sites-section">
      <h2>还需要别的工具？看看姊妹站</h2>
      <p class="sister-section-desc">HyperGrad 一共 5 个工具站，全部本地处理、互不打扰——挑一个继续探索。</p>
      <div class="sister-cards">
        {sisters.map(s => (
          <a href={s.href} class="sister-card" target="_blank" rel="noopener">
            <div class="sister-card-head">
              <span class="sister-card-icon">{s.icon}</span>
              <div class="sister-card-head-text">
                <strong>{s.shortName}</strong>
                <span class="sister-card-href">{s.href.replace('https://', '')}</span>
              </div>
            </div>
            <p class="sister-card-slogan">{s.slogan}</p>
            <ul class="sister-card-tools">
              {s.hot.slice(0, 5).map(h => (
                <li>{h.name}</li>
              ))}
            </ul>
            <span class="sister-card-cta">访问 {s.shortName} →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- 关于 -->
    <section class="seo-content">
      <h2>关于 HyperGrad AI</h2>
      <p>
        HyperGrad AI 是一个 AI 工具集合，收录 <strong>{totalTools} 个</strong>工具，覆盖 AI 写作、翻译、总结、对话、Prompt 工程、
        代码理解、Token 估算、文档与图像处理。与其他在线 AI 站不同，本站采用 <strong>BYOK（Bring Your Own Key，自带密钥）</strong>模式：
        你自行申请 AI 服务商的 API Key，填入工具，由浏览器直接调用对应 AI 官方 API。这意味着：
      </p>
      <ul>
        <li><strong>密钥安全</strong>：API Key 仅存储在你浏览器的 localStorage，从不通过网络发送到我们的服务器。</li>
        <li><strong>零中转</strong>：你的输入和 AI 的输出在浏览器与 AI 服务商之间直传，<strong>不经过我们的任何服务器</strong>。</li>
        <li><strong>零存储</strong>：我们不记录、不存储你的任何请求与生成内容。</li>
        <li><strong>零成本</strong>：我们无需为 API 调用付费，工具本身永久免费；你只为自己的实际用量向 AI 服务商付费。</li>
      </ul>

      <h3>BYOK 是什么？为什么更便宜？</h3>
      <p>
        BYOK 即 Bring Your Own Key。多数在线 AI 站点采用"代付"模式：你充值给站点，站点用自家 Key 调用 API，
        再加价卖给你 Token——通常比 API 原价贵 3-10 倍，且你的数据会经过站点服务器。BYOK 把选择权还给你：
        你直接向 AI 服务商（如深度求索、OpenAI、Anthropic、智谱）申请 Key，
        按官方价付费，<strong>没有中间商赚差价</strong>，数据也不经我们手。
      </p>
      <p>
        成本对比：用 <strong>DeepSeek（深度求索）</strong>，百万 Token 输入仅需 ¥1、输出 ¥2，生成一篇 1000 字文章不到一分钱；
        ChatGPT Plus 月费 ¥150，按官方 API 算你每月大概能用 ¥1500 等价的 Token。轻度用户用 BYOK 一年可能花不到 ¥10。
      </p>

      <h3>支持的 AI 服务商</h3>
      <ul>
        <li><strong>DeepSeek（深度求索）</strong>：国产模型，最便宜，中文表现优秀。推荐首选。<a href="https://platform.deepseek.com/api_keys" target="_blank" rel="noopener">申请 Key →</a></li>
        <li><strong>OpenAI</strong>：GPT-4o / GPT-4o-mini，质量顶尖，需海外信用卡。<a href="https://platform.openai.com/api-keys" target="_blank" rel="noopener">申请 Key →</a></li>
        <li><strong>Anthropic Claude</strong>：Claude 3.5 Sonnet 写作质量公认最佳。<a href="https://console.anthropic.com/settings/keys" target="_blank" rel="noopener">申请 Key →</a></li>
        <li><strong>智谱 GLM</strong>：国产模型，GLM-4-Flash 完全免费。<a href="https://open.bigmodel.cn/usercenter/proj-mgmt/apikeys" target="_blank" rel="noopener">申请 Key →</a></li>
      </ul>
      <p>
        四家服务商可在工具内一键切换，密钥分别保存。同一个工具（如 AI 写作）今天用 DeepSeek 省钱，明天换 Claude 求最佳质量，无缝切换。
      </p>

      <h3>纯前端工具（无需 API Key）</h3>
      <p>
        除了 BYOK AI 工具，本站还提供 <strong>{localCount} 个纯前端工具</strong>，无需任何配置即可使用：
        Prompt 提示词库、系统提示词生成器、Token 计数器、Markdown 转换器、图片压缩。这些工具 100% 在浏览器本地运算，
        数据不离开你的设备，适合处理敏感内容。
      </p>

      <h3>与 DeepSeal 的关系</h3>
      <p>
        HyperGrad AI 与 <a href="https://hypergrad.cn" target="_blank" rel="noopener">DeepSeal 加密笔记应用</a>
        同属 HyperGrad 生态。DeepSeal 是一款本地加密的桌面笔记应用，采用三层信封加密架构，数据永不离开设备。
        把 AI 生成的优质内容保存到 DeepSeal，是兼顾效率与隐私的完整工作流。两款产品共享同一个核心理念：<strong>你的数据只有你说了算</strong>。
      </p>
      <p>
        也欢迎访问姊妹站点 <a href="https://crypto.hypergrad.cn" target="_blank" rel="noopener">HyperGrad Crypto</a>
        （16 个加密工具）与 <a href="https://devtools.hypergrad.cn" target="_blank" rel="noopener">HyperGrad DevTools</a>
        （20+ 开发者工具），同样 100% 本地处理。
      </p>
    </section>
    <!-- Hero（精简为一行醒目标语） -->
    <section class="home-hero home-hero-compact home-hero-compact--bottom">
      <h1>纯前端 AI 工具箱 · <span class="hero-accent">密钥本地 · 直连官方 API · 零中转</span></h1>
      <div class="privacy-badge">BYOK 密钥本地存储 · 请求直连 AI 官方 · 我们零存储零 API 成本</div>
    </section>

  </main>

  <Footer />

  <style is:global>
    .quick-nav {
      margin: 28px 0 8px;
      padding: 16px 20px;
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 12px;
    }
    .quick-nav-title {
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 10px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }
    .quick-nav-chips {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 4px;
      scrollbar-width: thin;
    }
    .quick-nav-chips::-webkit-scrollbar { height: 6px; }
    .quick-nav-chips::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    .quick-chip {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 20px;
      font-size: 13px;
      color: var(--text);
      text-decoration: none;
      white-space: nowrap;
      transition: all 0.15s ease;
    }
    .quick-chip:hover {
      background: var(--blue);
      color: #fff;
      border-color: var(--blue);
    }
    .quick-chip-icon { font-size: 14px; }

    /* 精简版 hero：单行醒目标语 */
    .home-hero-compact {
      text-align: center;
      padding: var(--space-xl) var(--space-lg) var(--space-lg);
      margin-bottom: var(--space-xl);
    }
    .home-hero-compact h1 {
      font-family: var(--font-sans);
      font-size: 30px;
      font-weight: 800;
      color: var(--text);
      line-height: 1.3;
      margin: 0 0 var(--space-sm);
      letter-spacing: -0.02em;
    }
    .home-hero-compact .hero-accent {
      color: var(--blue);
    }
    .home-hero-compact .privacy-badge {
      font-size: 13px;
      padding: 6px 16px;
    }
  
    /* SISTER-CARDS — 首页姊妹站大卡片 */
    .sister-sites-section {
      margin: var(--space-xl) 0 var(--space-lg);
      padding-top: var(--space-lg);
      border-top: 1px solid var(--border);
    }
    .sister-sites-section h2 {
      font-size: 22px; font-weight: 700;
      color: var(--text);
      margin: 0 0 6px;
      letter-spacing: -0.01em;
    }
    .sister-section-desc {
      font-size: 14px; color: var(--text-muted);
      margin: 0 0 20px;
    }
    .sister-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 16px;
    }
    .sister-card {
      display: flex; flex-direction: column; gap: 10px;
      padding: 18px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    }
    .sister-card:hover {
      border-color: var(--blue);
      box-shadow: 0 8px 24px rgba(99, 102, 241, 0.15);
      transform: translateY(-2px);
    }
    .sister-card-head {
      display: flex; align-items: center; gap: 12px;
    }
    .sister-card-icon {
      font-size: 22px; line-height: 1;
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      background: var(--blue-bg);
      border-radius: 12px;
      flex-shrink: 0;
    }
    .sister-card-head-text {
      display: flex; flex-direction: column; gap: 2px;
      min-width: 0;
    }
    .sister-card-head-text strong {
      font-size: 16px; font-weight: 700; color: var(--text);
    }
    .sister-card-href {
      font-size: 11px; color: var(--text-muted);
    }
    .sister-card-slogan {
      font-size: 13px; color: var(--text-muted);
      line-height: 1.5; margin: 0;
    }
    .sister-card-tools {
      list-style: none; padding: 0; margin: 4px 0 0;
      display: flex; flex-wrap: wrap; gap: 6px 8px;
    }
    .sister-card-tools li {
      font-size: 12px; color: var(--text);
      background: var(--bg-soft);
      padding: 3px 9px;
      border-radius: 12px;
      white-space: nowrap;
    }
    .sister-card-cta {
      margin-top: auto;
      font-size: 13px; font-weight: 600;
      color: var(--blue);
    }

  </style>
</body>
</html>
